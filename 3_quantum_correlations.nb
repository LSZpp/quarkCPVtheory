      RowBox[{
      "Rules", " ", "for", " ", "the", " ", "definition", " ", "of", " ", 
       "r1"}], "*)"}], 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
