Cell[CellGroupData[{

Cell["c) flavour eigenstate 2: Kpipi0 and K3pi", "Subsubsection",
 CellChangeTimes->{{3.982992652957593*^9, 
  3.9829926861510763`*^9}},ExpressionUUID->"f3ecd610-3706-443b-a72c-\
c48470c7e108"],

Cell["\<\
Now onto the general case, here the constraint that the two sides do not have \
extra kinematic degrees of freedom loosen. 
Let us first consider the most general case, where both side has an extra \
kinematic degree of freedom. 
We symbolically encode this into a variable x, which is between -1 and 1.  
First define amplitudes\
\>", "Text",
 CellChangeTimes->{{3.98294161658244*^9, 3.9829416205291777`*^9}, {
   3.9829416829509907`*^9, 3.9829418345947647`*^9}, {3.982941925886631*^9, 
   3.982941927193557*^9}, {3.982944574164173*^9, 3.98294462731042*^9}, {
   3.9829926897558403`*^9, 3.982992735677052*^9}, {3.983004459448021*^9, 
   3.98300453505488*^9}, {3.983004590485434*^9, 3.983004593783016*^9}, 
   3.9830048805244293`*^9, {3.983007827698436*^9, 
   3.983007827853126*^9}},ExpressionUUID->"cb92898d-80a2-49ad-aa11-\
ed77bf6102dd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "A1", ",", "A1bar", ",", "A2", ",", "A2bar", ",", "Acorr", ",", "Ycorr", ",",
    "x", ",", "y"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Acorr", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"A1", "[", "x", "]"}], " ", 
    RowBox[{"A2bar", "[", "y", "]"}]}], "-", 
   RowBox[{
    RowBox[{"A1bar", "[", "x", "]"}], " ", 
    RowBox[{"A2", "[", "y", "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Ycorr", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Acorr", "[", 
        RowBox[{"x", ",", "y"}], "]"}], " ", 
       RowBox[{"Conjugate", "[", 
        RowBox[{"Acorr", "[", 
         RowBox[{"x", ",", "y"}], "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.982943260066079*^9, 3.982943288312698*^9}, 
   3.982944400913124*^9, 3.982944609209736*^9, 3.982944760089761*^9, 
   3.9829448239816103`*^9, {3.982944912923224*^9, 3.982944915960956*^9}, {
   3.983004581039523*^9, 3.983004618398814*^9}, {3.983004761650114*^9, 
   3.983004794753387*^9}, {3.983004855721306*^9, 3.9830048644756527`*^9}, 
   3.983009800640279*^9, {3.983016968473284*^9, 3.983016969141015*^9}, {
   3.983022020502627*^9, 3.983022030330649*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"c078a567-ac0d-47f5-8695-7d16909cbda3"],

Cell[BoxData[
 RowBox[{
  SubsuperscriptBox["\[Integral]", 
   RowBox[{"-", "1"}], "1"], 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SubsuperscriptBox["\[Integral]", 
      RowBox[{"-", "1"}], "1"], 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{"A1bar", "[", "x", "]"}]}], " ", 
          RowBox[{"A2", "[", "y", "]"}]}], "+", 
         RowBox[{
          RowBox[{"A1", "[", "x", "]"}], " ", 
          RowBox[{"A2bar", "[", "y", "]"}]}]}], ")"}], " ", 
       RowBox[{"Conjugate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           RowBox[{"A1bar", "[", "x", "]"}]}], " ", 
          RowBox[{"A2", "[", "y", "]"}]}], "+", 
         RowBox[{
          RowBox[{"A1", "[", "x", "]"}], " ", 
          RowBox[{"A2bar", "[", "y", "]"}]}]}], "]"}]}], 
      RowBox[{"\[DifferentialD]", "x"}]}]}], ")"}], 
   RowBox[{"\[DifferentialD]", "y"}]}]}]], "Output",
 CellChangeTimes->{
  3.982943294870442*^9, 3.9829444043980093`*^9, 3.9829446098847017`*^9, 
   3.982944766692856*^9, 3.98294482453899*^9, 3.9829449175465193`*^9, 
   3.982989891485436*^9, 3.9830046192699003`*^9, 3.983004775087817*^9, 
   3.983004816775731*^9, 3.983004865567741*^9, 3.983006958756093*^9, 
   3.983009817753456*^9, {3.983016873507346*^9, 3.9830169011133413`*^9}, 
   3.983016975104653*^9, {3.983022031049769*^9, 3.983022046553019*^9}, {
   3.983022108718173*^9, 3.9830221328803062`*^9}, 3.9830830339788303`*^9, 
   3.9834291185254908`*^9},
 CellLabel->"Out[64]=",ExpressionUUID->"7b0dfad5-fbf8-4a0c-b73b-9c6e2f8f92fe"]
}, Open  ]],

Cell["\<\
To prepare for identifying Ycorr in terms of the integrated observables, \
expansion is needed\
\>", "Text",
 CellChangeTimes->{{3.983006465216416*^9, 
  3.983006482572885*^9}},ExpressionUUID->"1afa75a5-9d9e-420f-ac3b-\
9b253aabdc87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Ycorr", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FixedPoint", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"#", "/.", " ", 
           RowBox[{
            RowBox[{"Conjugate", "[", 
             RowBox[{"a_", "+", "b_"}], "]"}], ":>", 
            RowBox[{
             RowBox[{"Conjugate", "[", "a", "]"}], "+", 
             RowBox[{"Conjugate", "[", "b", "]"}]}]}]}], "/.", " ", 
          RowBox[{
           RowBox[{"Conjugate", "[", 
            RowBox[{"a_", " ", "b_"}], "]"}], ":>", 
           RowBox[{
            RowBox[{"Conjugate", "[", "a", "]"}], " ", 
            RowBox[{"Conjugate", "[", "b", "]"}]}]}]}], ")"}], "&"}], ",", 
       RowBox[{
        RowBox[{"Acorr", "[", 
         RowBox[{"x", ",", "y"}], "]"}], " ", 
        RowBox[{"Conjugate", "[", 
         RowBox[{"Acorr", "[", 
          RowBox[{"x", ",", "y"}], "]"}], "]"}]}]}], "]"}], "//", "Expand"}], 
    "//", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"term", ",", 
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"xpart", ",", "ypart", ",", "pref"}], "}"}], ",", 
             RowBox[{
              RowBox[{"xpart", "=", 
               RowBox[{"Times", "@@", 
                RowBox[{"Cases", "[", 
                 RowBox[{
                  RowBox[{"List", "@@", "term"}], ",", 
                  RowBox[{"f_", "/;", 
                   RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "x"}], "]"}]}]}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"ypart", "=", 
               RowBox[{"Times", "@@", 
                RowBox[{"Cases", "[", 
                 RowBox[{
                  RowBox[{"List", "@@", "term"}], ",", 
                  RowBox[{"f_", "/;", 
                   RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "y"}], "]"}]}]}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"pref", "=", 
               RowBox[{"Times", "@@", 
                RowBox[{"Cases", "[", 
                 RowBox[{
                  RowBox[{"List", "@@", "term"}], ",", 
                  RowBox[{"f_", "/;", 
                   RowBox[{
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "x"}], "]"}], "&&", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "y"}], "]"}]}]}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"pref", " ", 
               RowBox[{"Integrate", "[", 
                RowBox[{"xpart", ",", 
                 RowBox[{"{", 
                  RowBox[{"x", ",", 
                   RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], " ", 
               RowBox[{"Integrate", "[", 
                RowBox[{"ypart", ",", 
                 RowBox[{"{", 
                  RowBox[{"y", ",", 
