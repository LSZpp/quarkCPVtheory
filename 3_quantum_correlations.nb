Cell[TextData[{
 "Now onto the general case. Consider, for example, Kpi v. K3pi.  With K3pi \
there is also the coherence factor \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"COH", "\[LongEqual]", 
         StyleBox["R", "TI"], 
         SuperscriptBox[
          StyleBox["e", FontSlant -> "Plain"], 
          RowBox[{"-", 
            StyleBox["i", FontSlant -> "Plain"], "\[Delta]"}]], 
         "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["A", "TI"], "*"], 
            OverscriptBox[
             StyleBox["A", "TI"], "_"]}], 
          RowBox[{
            StyleBox["A", "TI"], 
            OverscriptBox[
             StyleBox["A", "TI"], "_"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "\\text{COH} = R\\mathrm{e}^{-\\mathrm{i}\\delta} = \\frac{A^* \
\\bar{A}}{A\\bar{A}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "89b0e88b-ea83-45c7-922b-1f910f0feea0"],
 "\nGood. Now consider again the two separate cases where the kaon sign flips \
and the kaon sign does not flip"
}], "Text",
 CellChangeTimes->{{3.98294161658244*^9, 3.9829416205291777`*^9}, {
  3.9829416829509907`*^9, 3.9829418345947647`*^9}, {3.982941925886631*^9, 
  3.982941927193557*^9}, {3.982944574164173*^9, 
  3.98294462731042*^9}},ExpressionUUID->"cb92898d-80a2-49ad-aa11-\
ed77bf6102dd"],

