        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"r2", "^", "2"}], " ", "p2"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
