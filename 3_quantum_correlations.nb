Cell[CellGroupData[{

Cell["1) Definitions of quantum correlations", "Subsection",
 CellChangeTimes->{{3.982729584095584*^9, 3.9827296019977818`*^9}, {
   3.982815037116514*^9, 3.982815043499942*^9}, 3.982854018185688*^9, {
   3.9829009873436937`*^9, 
   3.982901039099682*^9}},ExpressionUUID->"33f63465-8026-4577-a31f-\
942af1b8c1f3"],

Cell[TextData[{
 "Consider an C-odd state, and neglect mixing at the moment. In this case it \
is possible to write down the decay of \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["J", "TI"], "/", "\[Psi]", "\[Rule]", 
         SubscriptBox[
          StyleBox["D", "TI"], "0"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["D", "TI"], "_"], "0"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "J/\\psi \\rightarrow D_0 \\bar D_0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f5fc090b-23be-4e43-a2b9-463cac824328"],
 " . Say that the two ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["D", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "D^0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f499736-df40-4b19-bef6-ffe30f5a456a"],
 "s are quantum correlated so exactly which flavour each one has is not \
well-defined. In this case, let us say that the two are merely labelled as 1 \
and 2, and the decays of them to their respective final states are equipped \
to have amplitudes A1 and A2; and the decay to the same endstate but when \
they are equipped with opposite flavours are equipped to have amplitudes \
A1bar and A2bar. Then, the correlated amplitude is"
}], "Text",
 CellChangeTimes->{{3.982901047196043*^9, 3.982901067951329*^9}, {
  3.9829011220575533`*^9, 3.982901124212331*^9}, {3.982901177137382*^9, 
  3.982901350364953*^9}, {3.9829014098988867`*^9, 
  3.982901627840178*^9}},ExpressionUUID->"458326bc-c2df-4d52-aeed-\
1b1dc18148e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Acorr", " ", "=", " ", 
  RowBox[{
   RowBox[{"A1", " ", "A2bar"}], " ", "-", " ", 
   RowBox[{"A1bar", " ", "A2"}]}]}]], "Input",
 CellChangeTimes->{{3.982849745055361*^9, 3.982849809588806*^9}, {
   3.982849877487006*^9, 3.9828499090477543`*^9}, {3.982850011318664*^9, 
   3.982850055361534*^9}, {3.982850113151421*^9, 3.982850117478112*^9}, {
   3.982850173468684*^9, 3.982850174453691*^9}, {3.982901630480934*^9, 
   3.982901641622601*^9}, {3.982941000254127*^9, 3.982941040609342*^9}, 
   3.982941095463511*^9},
 CellLabel->"In[52]:=",ExpressionUUID->"8c432b08-67a1-4506-a7ce-4a40b97727fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", "A1bar"}], " ", "A2"}], "+", 
  RowBox[{"A1", " ", "A2bar"}]}]], "Output",
 CellChangeTimes->{
  3.982901704739485*^9, 3.98290173514207*^9, 3.982902401829619*^9, 
   3.982932278546812*^9, 3.982940511407399*^9, 3.982941052697775*^9, 
   3.982941107860656*^9, {3.982942281262478*^9, 3.9829423034063*^9}, {
   3.982942396882065*^9, 3.982942413771187*^9}, 3.982942562864739*^9, 
   3.982989891164926*^9, 3.983006958218216*^9, {3.983016873220738*^9, 
   3.983016900786224*^9}, 3.983016974621703*^9, 3.983022046329383*^9, {
   3.983022108529801*^9, 3.983022132683599*^9}, 3.983083033446431*^9, 
   3.983429117967031*^9},
 CellLabel->"Out[52]=",ExpressionUUID->"954b91dc-4d18-4594-9de8-2bac4cbb34df"]
}, Open  ]],

Cell["Therefore the correlated yield is ", "Text",
 CellChangeTimes->{{3.982901648307226*^9, 
  3.982901669714172*^9}},ExpressionUUID->"8d24636d-8d4d-48ef-ae52-\
7c8b2251d8a9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Ycorr", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"Expand", "[", 
    RowBox[{"Acorr", "*", 
     RowBox[{"Conjugate", "[", "Acorr", "]"}]}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982901673345789*^9, 3.9829016938671303`*^9}, {
   3.982901740360894*^9, 3.9829017814373007`*^9}, {3.982942205745555*^9, 
   3.9829422734028063`*^9}, 3.982942322370521*^9, {3.982942378158729*^9, 
   3.98294238749642*^9}},
 CellLabel->"In[53]:=",ExpressionUUID->"1c4591c1-4887-4461-a371-e636f00324b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "A1bar"}], " ", "A2"}], "+", 
    RowBox[{"A1", " ", "A2bar"}]}], ")"}], " ", 
  RowBox[{"Conjugate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "A1bar"}], " ", "A2"}], "+", 
    RowBox[{"A1", " ", "A2bar"}]}], "]"}]}]], "Output",
 CellChangeTimes->{
  3.982901704741078*^9, {3.982901735143659*^9, 3.982901782172618*^9}, 
