Cell["\<\
I want to start with the yields for a process where we have a D meson against \
a CP odd / CP even state.
I also want to add in the effects of D0-D0bar mixing. 
Firstly start with the amplitudes. Use lambda to define whether the D is CP \
odd or CP even.
Then invert the sign to define whether the signal side D is CPodd or CPeven.\
\>", "Text",
 CellChangeTimes->{{3.983358590329173*^9, 3.983358650232836*^9}, {
   3.983358721891759*^9, 3.983358732182661*^9}, {3.983359344388365*^9, 
   3.983359373912334*^9}, {3.983359431858885*^9, 3.983359452074449*^9}, 
   3.983429106406426*^9, {3.983433296895666*^9, 3.983433357226609*^9}, {
   3.983433697481131*^9, 3.983433708741663*^9}, {3.983434466708274*^9, 
   3.983434490979885*^9}},ExpressionUUID->"bd43ec8a-8184-4ee0-b0a6-\
c02703d8e72d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"AF", " ", "=", " ", "1"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AbarF", " ", "=", " ", 
   RowBox[{"r", " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "I"}], " ", "spd"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AmpBFD", "[", "lambda_", "]"}], "[", "t_", "]"}], ":=", 
   RowBox[{"Expand", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"gPxy", "[", "t", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{"AF", "-", 
        RowBox[{"lambda", " ", "AbarF"}]}], ")"}]}], "+", 
     RowBox[{
      RowBox[{"gMxy", "[", "t", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{"AbarF", "-", 
        RowBox[{"lambda", " ", "AF"}]}], ")"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AmpBFDminus", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"AmpBFD", "[", 
     RowBox[{"+", "1"}], "]"}], "[", "t", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AmpBFDplus", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"AmpBFD", "[", 
     RowBox[{"-", "1"}], "]"}], "[", "t", "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.983433360388226*^9, 3.9834333753720913`*^9}, 
   3.983433443713151*^9, {3.983433510042733*^9, 3.983433537384424*^9}, {
   3.983433808595392*^9, 3.983433809215019*^9}, 3.9834338581681833`*^9, {
   3.983434460958797*^9, 3.9834344621585693`*^9}},
 CellLabel->
  "In[146]:=",ExpressionUUID->"6836a15b-89ac-4734-b4aa-4944f8badfbe"],

Cell[TextData[{
 "The branching fraction is given as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["B", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["D", "TI"], "-"], "\[Rule]", 
             StyleBox["F", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["N", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["F", "TI"], "|", 
                SubscriptBox[
                 StyleBox["T", "TI"], "+"]}], ")"}], "/", "\[Epsilon]", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["F", "TI"], "|", 
                SubscriptBox[
                 StyleBox["T", "TI"], "+"]}], ")"}]}], 
          RowBox[{
            StyleBox["N", "TI"], 
            RowBox[{"(", 
              SubscriptBox[
               StyleBox["T", "TI"], "+"], ")"}], "/", "\[Epsilon]", 
            RowBox[{"(", 
              SubscriptBox[
               StyleBox["T", "TI"], "+"], ")"}]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "B(D_- \\rightarrow F) = \\frac{N(F|T_+) / \\varepsilon(F|T_+)}{N(T_+) / \
\\varepsilon(T_+)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "26686643-c90c-40ef-b174-01da25162fa1"],
 "  and  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["B", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["D", "TI"], "+"], "\[Rule]", 
             StyleBox["F", "TI"]}], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["N", "TI"], 
            RowBox[{"(", 
              RowBox[{
                StyleBox["F", "TI"], "|", 
                SubscriptBox[
                 StyleBox["T", "TI"], "-"]}], ")"}], "/", "\[Epsilon]", 
            RowBox[{"(", 
              RowBox[{
                StyleBox["F", "TI"], "|", 
                SubscriptBox[
                 StyleBox["T", "TI"], "-"]}], ")"}]}], 
          RowBox[{
            StyleBox["N", "TI"], 
            RowBox[{"(", 
              SubscriptBox[
               StyleBox["T", "TI"], "-"], ")"}], "/", "\[Epsilon]", 
            RowBox[{"(", 
              SubscriptBox[
               StyleBox["T", "TI"], "-"], ")"}]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "B(D_+ \\rightarrow F) = \\frac{N(F|T_-) / \\varepsilon(F|T_-)}{N(T_-) / \
\\varepsilon(T_-)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "610db0b6-d63d-48f9-a614-f0910464e7ec"],
 ", which should be the square of the amplitudes:"
}], "Text",
 CellChangeTimes->{
  3.983433504135456*^9, {3.983433549826215*^9, 3.983433612422385*^9}, {
   3.983433667361761*^9, 
   3.9834336850330877`*^9}},ExpressionUUID->"f27c654a-603d-4067-a7b5-\
f6dad1e980b8"],

