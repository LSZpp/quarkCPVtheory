Cell[CellGroupData[{

Cell["b) flavour eigenstate", "Subsubsection",
 CellChangeTimes->{{3.9829411344200277`*^9, 
  3.982941139036783*^9}},ExpressionUUID->"170e4900-6ac8-45ea-89b0-\
3f6fa5a0926a"],

Cell["\<\
Same idea, but work with a special case and a general case. 
Special case is that the two sides are the same, for example Kpi v. Kpi. In \
this case, two cases can happen: either the kaon charge is identical, or the \
kaon charge is flipped. Neglecting DCS / charm mixing possibility, the equal \
case should be zero. Indeed,\
\>", "Text",
 CellChangeTimes->{{3.982941164665263*^9, 3.98294129422196*^9}, {
  3.9829415093122253`*^9, 3.9829415106949453`*^9}, {3.982941588715144*^9, 
  3.9829415891589127`*^9}, {3.9829418216790867`*^9, 
  3.982941823652903*^9}},ExpressionUUID->"4ca044ab-0b39-46e6-90d9-\
1fead9035843"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"YcorrFlavourSameFlip", " ", "=", 
  RowBox[{
   RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Ycorr", "/.", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"r2", "->", "r1"}], ",", 
        RowBox[{"spd2", "->", 
         RowBox[{"-", "spd1"}]}], ",", " ", 
        RowBox[{"A2", "->", "A1"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"Assumptions", "->", "STPHassumps"}]}], "\[IndentingNewLine]", 
    "]"}], "/.", " ", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", "A1", "]"}], "^", "2"}], "->", "p1"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", "A1", "]"}], "^", "4"}], "->", 
      RowBox[{"p1", "^", "2"}]}]}], "\[IndentingNewLine]", "}"}]}]}]], "Input",\

 CellChangeTimes->{{3.982940555968012*^9, 3.982940557766021*^9}, {
