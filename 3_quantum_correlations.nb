Cell[CellGroupData[{

Cell["1) Definitions of quantum correlations", "Subsection",
 CellChangeTimes->{{3.982729584095584*^9, 3.9827296019977818`*^9}, {
   3.982815037116514*^9, 3.982815043499942*^9}, 3.982854018185688*^9, {
   3.9829009873436937`*^9, 
   3.982901039099682*^9}},ExpressionUUID->"33f63465-8026-4577-a31f-\
942af1b8c1f3"],

Cell[TextData[{
 "Consider an C-odd state, and neglect mixing at the moment. In this case it \
is possible to write down the decay of \n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["J", "TI"], "/", "\[Psi]", "\[Rule]", 
         SubscriptBox[
          StyleBox["D", "TI"], "0"], 
         SubscriptBox[
          OverscriptBox[
           StyleBox["D", "TI"], "_"], "0"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "J/\\psi \\rightarrow D_0 \\bar D_0", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f5fc090b-23be-4e43-a2b9-463cac824328"],
 " . Say that the two ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["D", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "D^0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f499736-df40-4b19-bef6-ffe30f5a456a"],
 "s are quantum correlated so exactly which flavour each one has is not \
well-defined. In this case, let us say that the two are merely labelled as 1 \
and 2, and the decays of them to their respective final states are equipped \
to have amplitudes A1 and A2; and the decay to the same endstate but when \
they are equipped with opposite flavours are equipped to have amplitudes \
A1bar and A2bar. Then, the correlated amplitude is"
}], "Text",
 CellChangeTimes->{{3.982901047196043*^9, 3.982901067951329*^9}, {
  3.9829011220575533`*^9, 3.982901124212331*^9}, {3.982901177137382*^9, 
  3.982901350364953*^9}, {3.9829014098988867`*^9, 
  3.982901627840178*^9}},ExpressionUUID->"458326bc-c2df-4d52-aeed-\
1b1dc18148e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Acorr", " ", "=", " ", 
  RowBox[{
   RowBox[{"A1", " ", "A2bar"}], " ", "-", " ", 
   RowBox[{"A1bar", " ", "A2"}]}]}]], "Input",
 CellChangeTimes->{{3.982849745055361*^9, 3.982849809588806*^9}, {
   3.982849877487006*^9, 3.9828499090477543`*^9}, {3.982850011318664*^9, 
   3.982850055361534*^9}, {3.982850113151421*^9, 3.982850117478112*^9}, {
   3.982850173468684*^9, 3.982850174453691*^9}, {3.982901630480934*^9, 
   3.982901641622601*^9}, {3.982941000254127*^9, 3.982941040609342*^9}, 
   3.982941095463511*^9},
 CellLabel->"In[4]:=",ExpressionUUID->"8c432b08-67a1-4506-a7ce-4a40b97727fd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", "A1bar"}], " ", "A2"}], "+", 
  RowBox[{"A1", " ", "A2bar"}]}]], "Output",
 CellChangeTimes->{
  3.982901704739485*^9, 3.98290173514207*^9, 3.982902401829619*^9, 
   3.982932278546812*^9, 3.982940511407399*^9, 3.982941052697775*^9, 
   3.982941107860656*^9, {3.982942281262478*^9, 3.9829423034063*^9}, {
   3.982942396882065*^9, 3.982942413771187*^9}, 3.982942562864739*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"f19ff7a7-cc69-4bfc-ad90-a09b86578eb9"]
}, Open  ]],

Cell["Therefore the correlated yield is ", "Text",
 CellChangeTimes->{{3.982901648307226*^9, 
  3.982901669714172*^9}},ExpressionUUID->"8d24636d-8d4d-48ef-ae52-\
7c8b2251d8a9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Ycorr", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"Expand", "[", 
    RowBox[{"Acorr", "*", 
     RowBox[{"Conjugate", "[", "Acorr", "]"}]}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982901673345789*^9, 3.9829016938671303`*^9}, {
   3.982901740360894*^9, 3.9829017814373007`*^9}, {3.982942205745555*^9, 
   3.9829422734028063`*^9}, 3.982942322370521*^9, {3.982942378158729*^9, 
   3.98294238749642*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"1c4591c1-4887-4461-a371-e636f00324b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "A1bar"}], " ", "A2"}], "+", 
    RowBox[{"A1", " ", "A2bar"}]}], ")"}], " ", 
  RowBox[{"Conjugate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "A1bar"}], " ", "A2"}], "+", 
    RowBox[{"A1", " ", "A2bar"}]}], "]"}]}]], "Output",
 CellChangeTimes->{
  3.982901704741078*^9, {3.982901735143659*^9, 3.982901782172618*^9}, 
   3.982902403823203*^9, 3.982932278548518*^9, 3.982940511411117*^9, 
   3.982941107862376*^9, {3.982942246772191*^9, 3.982942323755657*^9}, {
   3.982942397044559*^9, 3.982942413782215*^9}, 3.982942562874082*^9},
 CellLabel->"Out[5]=",ExpressionUUID->"7f2532c5-39d7-4acb-b07d-526fdad78859"]
}, Open  ]],

Cell["\<\
It is better to express everything as probabilities. the easiest way to do \
this is, as in the previous notebook, to define everything in terms of the \
relative strong phases:\
\>", "Text",
 CellChangeTimes->{{3.982901803092239*^9, 3.982901861695717*^9}, {
  3.982902131171093*^9, 3.982902188714437*^9}, {3.9829022817905293`*^9, 
  3.982902282545781*^9}},ExpressionUUID->"e44ad00e-d1ca-401f-9eb3-\
567ecc87cfe9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"A1bar", " ", "=", " ", 
  RowBox[{"r1", " ", "A1", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", " ", "I"}], " ", "spd1"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"A2bar", " ", "=", " ", 
  RowBox[{"r2", " ", "A2", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", " ", "I"}], " ", "spd2"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"STPHassumps", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r1", "\[Element]", "Reals"}], ",", 
     RowBox[{"r2", "\[Element]", "Reals"}], ",", 
     RowBox[{"spd1", "\[Element]", "Reals"}], ",", 
     RowBox[{"spd2", "\[Element]", "Reals"}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98290219419319*^9, 3.982902300023518*^9}, {
   3.982932451560454*^9, 3.982932451683755*^9}, 3.982932591324555*^9, {
   3.9829409322254457`*^9, 3.982940933928123*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"96abd08c-7542-4147-a8d2-b9a8f9b18a42"],

Cell[BoxData[
 RowBox[{"A1", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "spd1"}]], " ", "r1"}]], "Output",
 CellChangeTimes->{
  3.982902407126607*^9, 3.982932278550269*^9, {3.982932442815234*^9, 
   3.982932453767989*^9}, 3.9829325915865593`*^9, 3.982940511421812*^9, {
   3.982940927451902*^9, 3.982940934568594*^9}, 3.982941107864169*^9, {
   3.982942281266561*^9, 3.9829423262830153`*^9}, {3.982942397049399*^9, 
   3.982942413785788*^9}, 3.9829425628763103`*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"f9ba6e0a-dc5b-43b9-bc68-6063f9d545d9"],

Cell[BoxData[
 RowBox[{"A2", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "spd2"}]], " ", "r2"}]], "Output",
 CellChangeTimes->{
  3.982902407126607*^9, 3.982932278550269*^9, {3.982932442815234*^9, 
   3.982932453767989*^9}, 3.9829325915865593`*^9, 3.982940511421812*^9, {
   3.982940927451902*^9, 3.982940934568594*^9}, 3.982941107864169*^9, {
   3.982942281266561*^9, 3.9829423262830153`*^9}, {3.982942397049399*^9, 
   3.982942413785788*^9}, 3.982942562876733*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"d76d8481-18ce-4539-87dd-bc8f88f58170"]
}, Open  ]],

Cell["\<\
Ultimately, we would like to express the correlated yield in terms of \
probabilities instead of amplitudes, so let\[CloseCurlyQuote]s do that\
\>", "Text",
 CellChangeTimes->{{3.982902326810133*^9, 3.982902334663353*^9}, {
  3.98290238537186*^9, 3.9829023929484673`*^9}, {3.98290243347283*^9, 
  3.9829024485885887`*^9}, {3.9829347532049103`*^9, 
  3.98293477723456*^9}},ExpressionUUID->"8d287822-93ef-43d6-81e9-\
f44a48c4be50"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"YcorrProb", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
     RowBox[{"Ycorr", ",", "\[IndentingNewLine]", 
      RowBox[{"Assumptions", "->", "STPHassumps"}]}], "\[IndentingNewLine]", 
     "]"}], "/.", " ", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"A1", " ", 
        RowBox[{"Conjugate", "[", "A1", "]"}]}], "->", "p1"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A2", " ", 
        RowBox[{"Conjugate", "[", "A2", "]"}]}], "->", "p2"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A1", " ", 
        RowBox[{"Conjugate", "[", "A1", "]"}], " ", 
        RowBox[{"r1", "^", "2"}]}], "->", "p1bar"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A2", " ", 
        RowBox[{"Conjugate", "[", "A2", "]"}], " ", 
        RowBox[{"r2", "^", "2"}]}], "->", "p2bar"}]}], "\[IndentingNewLine]", 
     "}"}]}], "/.", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Conjugate", "[", "A2", "]"}], "->", 
     RowBox[{"p2", "/", "A2"}]}], "}"}]}]}]], "Input",
 CellChangeTimes->{{3.982934532604327*^9, 3.9829345450475397`*^9}, {
   3.982934580681328*^9, 3.9829345869784203`*^9}, {3.982934789837716*^9, 
   3.9829348022412663`*^9}, {3.982942054164426*^9, 3.982942100599368*^9}, 
   3.9829422106207*^9, {3.982942489648156*^9, 3.982942525211711*^9}, 
   3.982942639104797*^9},
 CellLabel->"In[16]:=",ExpressionUUID->"f52a04d9-409a-4cc6-a990-20e82a8adf46"],

Cell[BoxData[
 RowBox[{"p1", " ", "p2", " ", 
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox["r1", "2"], "+", 
    SuperscriptBox["r2", "2"], "-", 
    RowBox[{"2", " ", "r1", " ", "r2", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"spd1", "-", "spd2"}], "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{
  3.9829345505912657`*^9, 3.9829348079097853`*^9, 3.982940511501886*^9, 
   3.982941107983964*^9, 3.982942057152672*^9, 3.982942101753253*^9, {
   3.982942281349943*^9, 3.9829423280841103`*^9}, {3.982942397117448*^9, 
   3.982942413908506*^9}, 3.98294249190374*^9, 3.9829425264321413`*^9, 
   3.982942562994995*^9, 3.982942640530315*^9},
 CellLabel->"Out[16]=",ExpressionUUID->"7c1b82aa-1c24-4009-b4c2-b975cc509a5c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["2) Coherence factors", "Subsection",
 CellChangeTimes->{{3.9829351980629463`*^9, 
  3.982935213777409*^9}},ExpressionUUID->"8d3a1c17-e404-4808-8f7b-\
789198db7cb1"],

Cell["\<\
Consider A1 decaying to a flavour eigenstate. 
Consider A2 decaying to two cases: 
a) CP eigenstate;
b) flavour eigenstate.
We look at a) and b) in turn.\
\>", "Text",
 CellChangeTimes->{
  3.982939508308617*^9, {3.982940030008381*^9, 
   3.982940030512061*^9}},ExpressionUUID->"bcd1077a-0a21-4774-99d0-\
a939567dab75"],

Cell[CellGroupData[{

Cell["a) CP eigenstate", "Subsubsection",
 CellChangeTimes->{{3.982940036075317*^9, 
  3.982940061435079*^9}},ExpressionUUID->"6e777189-eac1-43aa-802a-\
9eeb7cd970f2"],

Cell["\<\
In this case A2 = either A2bar or -A2bar, therefore r2 = 1 and spd2 is either \
0 or pi.  Run it for spd2 for 0 (CPeven) and pi (CPodd) separately:\
\>", "Text",
 CellChangeTimes->{{3.982940065590666*^9, 3.9829401859417887`*^9}, {
   3.982940239693797*^9, 3.982940278702078*^9}, {3.982940474749124*^9, 
   3.982940478523966*^9}, 3.982940604271517*^9, {3.98294067238717*^9, 
   3.9829406884734488`*^9}},ExpressionUUID->"89105a81-6eb3-43f5-a6fa-\
53c2a40812a6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"YcorrCPProb0", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Ycorr", "/.", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"r2", "->", "1"}], ",", 
         RowBox[{"spd2", "->", "0"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"Assumptions", "->", "STPHassumps"}]}], "\[IndentingNewLine]", 
     "]"}], "/.", " ", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"A1", " ", 
        RowBox[{"Conjugate", "[", "A1", "]"}]}], "->", "p1"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A2", " ", 
        RowBox[{"Conjugate", "[", "A2", "]"}]}], "->", "p2"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A1", " ", 
        RowBox[{"Conjugate", "[", "A1", "]"}], " ", 
        RowBox[{"r1", "^", "2"}]}], "->", "p1bar"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A2", " ", 
        RowBox[{"Conjugate", "[", "A2", "]"}], " ", 
        RowBox[{"r2", "^", "2"}]}], "->", "p2bar"}]}], "\[IndentingNewLine]", 
     "}"}]}], "/.", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Conjugate", "[", "A2", "]"}], "->", 
     RowBox[{"p2", "/", "A2"}]}], "}"}], " "}]}]], "Input",
 CellChangeTimes->{{3.982940202736833*^9, 3.982940222982107*^9}, {
   3.982940427425201*^9, 3.982940451121971*^9}, 3.982940498316389*^9, {
   3.982940594400488*^9, 3.9829406221189623`*^9}, {3.9829406650943747`*^9, 
   3.9829406670603724`*^9}, {3.982940883262002*^9, 3.982940885460762*^9}, {
   3.9829426602261257`*^9, 
   3.982942682695279*^9}},ExpressionUUID->"0e9537ee-abc7-48d2-ade1-\
a3b34b24ad1a"],

Cell[BoxData[
 RowBox[{"p1", " ", "p2", " ", 
  RowBox[{"(", 
