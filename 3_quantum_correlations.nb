Cell["Then the A observable for the flavour tag F is ", "Text",
 CellChangeTimes->{{3.983359543200646*^9, 
  3.9833595693800573`*^9}},ExpressionUUID->"a3faa26c-b547-480b-815e-\
caf0969b90b0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"A", " ", "=", " ", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"BFDminus", " ", "-", " ", "BFDplus"}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"BFDminus", " ", "+", " ", "BFDplus"}], ")"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.983359573685093*^9, 3.983359612224949*^9}},
 CellLabel->
  "In[172]:=",ExpressionUUID->"18fef78d-e113-40a2-b960-fac5ee616d72"],

Cell[BoxData[
 FractionBox[
  RowBox[{"y", "+", 
   RowBox[{
    SuperscriptBox["r", "2"], " ", "y"}], "-", 
   RowBox[{"2", " ", "r", " ", "R", " ", 
    RowBox[{"Cos", "[", "spd", "]"}]}]}], 
  RowBox[{"1", "+", 
   SuperscriptBox["r", "2"], "-", 
   RowBox[{"2", " ", "r", " ", "R", " ", "y", " ", 
    RowBox[{"Cos", "[", "spd", "]"}]}]}]]], "Output",
 CellChangeTimes->{{3.98335959493808*^9, 3.983359612584218*^9}, 
   3.98342911907837*^9, 3.983434051661734*^9, 3.983434582917746*^9},
 CellLabel->
  "Out[172]=",ExpressionUUID->"7eed5b32-afcc-4f7f-95ad-6d76db750693"]
}, Open  ]],

Cell["Check the truncation of A to different orders of y", "Text",
 CellChangeTimes->{{3.983434062183617*^9, 
  3.983434069412753*^9}},ExpressionUUID->"d362dcdd-5d88-48e4-9cf9-\
3557be03ee90"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"truncate", " ", "A", " ", "to", " ", 
    RowBox[{"O", "[", "y", "]"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ATruncY1", "=", 
    RowBox[{
     RowBox[{"Normal", "[", 
      RowBox[{"Series", "[", 
       RowBox[{"A", ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", "0", ",", "1"}], "}"}]}], "]"}], "]"}], "//", 
     "Expand"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"truncate", " ", "A", " ", "to", " ", 
     RowBox[{"O", "[", 
      RowBox[{"y", "^", "2"}], "]"}]}], "*)"}], "\n", 
   RowBox[{"ATruncY2", "=", 
    RowBox[{
     RowBox[{"Normal", "[", 
      RowBox[{"Series", "[", 
       RowBox[{"A", ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", "0", ",", "2"}], "}"}]}], "]"}], "]"}], "//", 
     "Expand"}]}]}]}]], "Input",
 CellChangeTimes->{{3.983434051695306*^9, 3.983434053604206*^9}, {
  3.983434121381407*^9, 3.983434126930768*^9}},
 CellLabel->
  "In[173]:=",ExpressionUUID->"e2a77324-414b-470b-a66a-c388a4958e6e"],

Cell[BoxData[
 RowBox[{"y", "-", 
  FractionBox[
   RowBox[{"2", " ", "r", " ", "R", " ", 
    RowBox[{"Cos", "[", "spd", "]"}]}], 
   RowBox[{"1", "+", 
    SuperscriptBox["r", "2"]}]], "-", 
  FractionBox[
   RowBox[{"4", " ", 
    SuperscriptBox["r", "2"], " ", 
    SuperscriptBox["R", "2"], " ", "y", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "spd", "]"}], "2"]}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["r", "2"]}], ")"}], "2"]]}]], "Output",
 CellChangeTimes->{3.983434127954129*^9, 3.983434585128207*^9},
 CellLabel->
  "Out[173]=",ExpressionUUID->"d16fda10-d881-4ad4-991c-ba1e713d0699"],

Cell[BoxData[
 RowBox[{"y", "-", 
  FractionBox[
   RowBox[{"2", " ", "r", " ", "R", " ", 
    RowBox[{"Cos", "[", "spd", "]"}]}], 
   RowBox[{"1", "+", 
    SuperscriptBox["r", "2"]}]], "+", 
  FractionBox[
   RowBox[{"2", " ", "r", " ", "R", " ", 
    SuperscriptBox["y", "2"], " ", 
    RowBox[{"Cos", "[", "spd", "]"}]}], 
   RowBox[{"1", "+", 
    SuperscriptBox["r", "2"]}]], "-", 
  FractionBox[
   RowBox[{"4", " ", 
    SuperscriptBox["r", "2"], " ", 
    SuperscriptBox["R", "2"], " ", "y", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "spd", "]"}], "2"]}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["r", "2"]}], ")"}], "2"]], "-", 
  FractionBox[
   RowBox[{"8", " ", 
    SuperscriptBox["r", "3"], " ", 
    SuperscriptBox["R", "3"], " ", 
    SuperscriptBox["y", "2"], " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "spd", "]"}], "3"]}], 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["r", "2"]}], ")"}], "3"]]}]], "Output",
 CellChangeTimes->{3.983434127954129*^9, 3.983434585129116*^9},
 CellLabel->
  "Out[174]=",ExpressionUUID->"0d970724-a5c0-41ea-90d7-80c25f182171"]
}, Open  ]],

Cell[TextData[{
 "Now move on to flavour v. flavour, which gives the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Zeta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\zeta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f03bdf6c-0407-45b5-b298-ddf7013f5c8f"],
 " observable. \nFor this, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Zeta]", 
          StyleBox["G", "TI"], 
          StyleBox["F", "TI"]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"\[CapitalGamma]", 
            SubscriptBox[
             RowBox[{"(", 
               RowBox[{
                 StyleBox["F", "TI"], "|", 
                 StyleBox["G", "TI"]}], ")"}], "SS"]}], 
          RowBox[{"\[CapitalGamma]", 
            SubscriptBox[
             RowBox[{"(", 
               RowBox[{
                 StyleBox["F", "TI"], "|", 
                 StyleBox["G", "TI"]}], ")"}], "OS"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\zeta^F_G = \\frac{\\Gamma(F|G)_{\\text{SS}}}{\\Gamma(F|G)_{\\text \
{OS}}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "38f294c3-07a1-4771-8270-f59d719f1426"],
 " and same definition applies for F = G. For opposite sign, "
}], "Text",
 CellChangeTimes->{{3.9833596244622593`*^9, 3.98335966460297*^9}, 
   3.9833597899907227`*^9, {3.9833598500579243`*^9, 3.9833598787365847`*^9}, {
   3.983360326587676*^9, 
   3.983360327566486*^9}},ExpressionUUID->"12c84adb-75ac-475d-96ea-\
10787c4458ff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RateFGSS", " ", "=", " ", 
  RowBox[{
   RowBox[{"rF", "^", "2"}], " ", "+", " ", 
   RowBox[{"rG", "^", "2"}], " ", "-", " ", 
   RowBox[{"2", " ", "RF", " ", "RG", " ", "rF", " ", "rG", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"spdF", " ", "-", " ", "spdG"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9833600499602118`*^9, 3.983360109808488*^9}, {
  3.983360336235075*^9, 3.983360337377534*^9}, {3.983360564158085*^9, 
  3.983360564309361*^9}, {3.983427247432816*^9, 3.983427247985023*^9}, {
  3.983433409436198*^9, 3.983433409887348*^9}},
 CellLabel->
  "In[175]:=",ExpressionUUID->"9649a2dc-be21-44ea-8df0-96b2aeb46467"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["rF", "2"], "+", 
  SuperscriptBox["rG", "2"], "-", 
  RowBox[{"2", " ", "rF", " ", "RF", " ", "rG", " ", "RG", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"spdF", "-", "spdG"}], "]"}]}]}]], "Output",
 CellChangeTimes->{3.983360110855341*^9, 3.98336037540615*^9, 
  3.983360564907488*^9, 3.9834272646572227`*^9, 3.983429119086444*^9, 
  3.9834346152150393`*^9},
 CellLabel->
  "Out[175]=",ExpressionUUID->"49f105df-0741-4655-82de-ee5acea33aa5"]
}, Open  ]],

Cell["For same sign,", "Text",
 CellChangeTimes->{{3.983360332309136*^9, 
  3.983360334258067*^9}},ExpressionUUID->"e79cf642-a575-41c7-98aa-\
f2045e19889d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RateFGOS", "=", " ", 
  RowBox[{"1", " ", "+", " ", 
   RowBox[{"rF", " ", "rG"}], " ", "-", " ", 
   RowBox[{"2", " ", "RF", " ", "RG", " ", "rF", " ", "rG", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"spdF", " ", "+", " ", "spdG"}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.98336034322538*^9, 3.9833603719527483`*^9}, {
  3.983360566645413*^9, 3.9833605668492613`*^9}, {3.9834272495093203`*^9, 
  3.983427250065814*^9}},
 CellLabel->
  "In[176]:=",ExpressionUUID->"65c60431-6c74-41fc-8cf3-7e4c77803acd"],

Cell[BoxData[
 RowBox[{"1", "+", 
  RowBox[{"rF", " ", "rG"}], "-", 
  RowBox[{"2", " ", "rF", " ", "RF", " ", "rG", " ", "RG", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"spdF", "+", "spdG"}], "]"}]}]}]], "Output",
 CellChangeTimes->{{3.983360366224551*^9, 3.9833603773790817`*^9}, 
   3.983360567466131*^9, {3.983427251591281*^9, 3.983427260831279*^9}, 
   3.983429119092894*^9, 3.98343461660529*^9},
 CellLabel->
  "Out[176]=",ExpressionUUID->"8476b241-359c-4b9f-be61-41ecd38cfacc"]
}, Open  ]],

Cell[TextData[{
 "Therefore, for F and G distinct, the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Zeta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\zeta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "518db17b-c5a2-444d-9bf4-9c1edd823f08"],
 " observable is "
}], "Text",
 CellChangeTimes->{{3.983360385291545*^9, 
  3.983360399332296*^9}},ExpressionUUID->"34855595-632a-4bb2-99ba-\
e72d4905fc6b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"zetaFG", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"RateFGSS", "/", "RateFGOS"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9833604032246857`*^9, 3.983360427892256*^9}},
 CellLabel->"In[85]:=",ExpressionUUID->"bac8c9e6-03b6-4f29-9641-7318f252d287"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["rF", "2"], "+", 
   SuperscriptBox["rG", "2"], "-", 
   RowBox[{"2", " ", "rF", " ", "RF", " ", "rG", " ", "RG", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"spdF", "-", "spdG"}], "]"}]}]}], 
  RowBox[{"1", "+", 
   RowBox[{"rF", " ", "rG"}], "-", 
   RowBox[{"2", " ", "rF", " ", "RF", " ", "rG", " ", "RG", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"spdF", "+", "spdG"}], "]"}]}]}]]], "Output",
 CellChangeTimes->{
  3.9833604282911997`*^9, 3.983360568953292*^9, {3.9834272555835953`*^9, 
   3.98342726643001*^9}, 3.983429119110035*^9},
 CellLabel->"Out[85]=",ExpressionUUID->"b9f7d238-b386-41c8-8987-54cb3cb455dc"]
}, Open  ]],

Cell[TextData[{
 "For F and G identical, the  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Zeta]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\zeta", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2fe9acd1-a20a-476e-b760-426a6dba8efc"],
 " observable is "
}], "Text",
 CellChangeTimes->{{3.983360452969458*^9, 
  3.9833604603721533`*^9}},ExpressionUUID->"79b68820-69d0-4381-ad31-\
be87311aeb0d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"zetaGG", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"RateFGSS", "/", "RateFGOS"}], ")"}], "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"rF", "->", "rG"}], ",", 
      RowBox[{"RF", "->", "RG"}], ",", 
      RowBox[{"spdF", "->", "spdG"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.983360526220037*^9, 3.983360528915517*^9}, {
