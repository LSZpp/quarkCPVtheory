Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "A1", ",", "A1bar", ",", "A2", ",", "A2bar", ",", "Acorr", ",", "Ycorr", ",",
    "x", ",", "y"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Acorr", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"A1", "[", "x", "]"}], " ", 
    RowBox[{"A2", "[", "y", "]"}]}], "-", 
   RowBox[{
    RowBox[{"A1bar", "[", "x", "]"}], " ", 
    RowBox[{"A2bar", "[", "y", "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ycorr", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FixedPoint", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"#", "/.", " ", 
           RowBox[{
            RowBox[{"Conjugate", "[", 
             RowBox[{"a_", "+", "b_"}], "]"}], ":>", 
            RowBox[{
             RowBox[{"Conjugate", "[", "a", "]"}], "+", 
             RowBox[{"Conjugate", "[", "b", "]"}]}]}]}], "/.", " ", 
          RowBox[{
           RowBox[{"Conjugate", "[", 
            RowBox[{"a_", " ", "b_"}], "]"}], ":>", 
           RowBox[{
            RowBox[{"Conjugate", "[", "a", "]"}], " ", 
            RowBox[{"Conjugate", "[", "b", "]"}]}]}]}], ")"}], "&"}], ",", 
       RowBox[{
        RowBox[{"Acorr", "[", 
         RowBox[{"x", ",", "y"}], "]"}], " ", 
        RowBox[{"Conjugate", "[", 
         RowBox[{"Acorr", "[", 
          RowBox[{"x", ",", "y"}], "]"}], "]"}]}]}], "]"}], "//", "Expand"}], 
    "//", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Total", "[", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"term", ",", 
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"xpart", ",", "ypart", ",", "pref"}], "}"}], ",", 
             RowBox[{
              RowBox[{"xpart", "=", 
               RowBox[{"Times", "@@", 
                RowBox[{"Cases", "[", 
                 RowBox[{
                  RowBox[{"List", "@@", "term"}], ",", 
                  RowBox[{"f_", "/;", 
                   RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "x"}], "]"}]}]}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"ypart", "=", 
               RowBox[{"Times", "@@", 
                RowBox[{"Cases", "[", 
                 RowBox[{
                  RowBox[{"List", "@@", "term"}], ",", 
                  RowBox[{"f_", "/;", 
                   RowBox[{"!", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "y"}], "]"}]}]}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"pref", "=", 
               RowBox[{"Times", "@@", 
                RowBox[{"Cases", "[", 
                 RowBox[{
                  RowBox[{"List", "@@", "term"}], ",", 
                  RowBox[{"f_", "/;", 
                   RowBox[{
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "x"}], "]"}], "&&", 
                    RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "y"}], "]"}]}]}]}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"pref", " ", 
               RowBox[{"Integrate", "[", 
                RowBox[{"xpart", ",", 
                 RowBox[{"{", 
                  RowBox[{"x", ",", 
                   RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], " ", 
               RowBox[{"Integrate", "[", 
                RowBox[{"ypart", ",", 
                 RowBox[{"{", 
                  RowBox[{"y", ",", 
                   RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}]}]}], 
            "]"}]}], "]"}], ",", 
         RowBox[{"List", "@@", "#"}]}], "]"}], "]"}], "&"}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Expand", "[", "Ycorr", "]"}], "/.", " ", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "Rules", " ", "for", " ", "the", " ", "definition", " ", "of", " ", 
      "p1"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A1", "[", "x", "]"}], "]"}], " ", 
         RowBox[{"A1", "[", "x", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", "p1"}], ",", 
