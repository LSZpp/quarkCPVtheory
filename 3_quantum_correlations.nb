Cell["Now expand Yplus with updated rules for probabilities", "Text",
 CellChangeTimes->{{3.9830825242026176`*^9, 
  3.9830825486741047`*^9}},ExpressionUUID->"a20126e4-b052-4a16-8146-\
45b4cac40549"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Expand", "[", "Yplus", "]"}], "/.", " ", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"(*", "Probabilities", "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A1", "[", "x", "]"}], "]"}], " ", 
         RowBox[{"A1", "[", "x", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"1", "/", "2"}], ",", "1"}], "}"}]}], "]"}], "->", 
      "F1plus"}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A1bar", "[", "x", "]"}], "]"}], " ", 
         RowBox[{"A1bar", "[", "x", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"1", "/", "2"}], ",", "1"}], "}"}]}], "]"}], "->", 
      "F1minus"}], ",", 
     RowBox[{"(*", 
      RowBox[{"opposite", " ", "bin"}], "*)"}], 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2", "[", "y", "]"}], "]"}], " ", 
         RowBox[{"A2", "[", "y", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", "p2"}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2bar", "[", "y", "]"}], "]"}], " ", 
         RowBox[{"A2bar", "[", "y", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"r2", "^", "2"}], " ", "p2"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Interference", " ", "term", " ", "for", " ", "KSpipi"}], 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A1", "[", "x", "]"}], "]"}], " ", 
         RowBox[{"A1bar", "[", "x", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"1", "/", "2"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"F1plus", " ", "F1minus"}], "]"}], " ", 
       RowBox[{"(", 
        RowBox[{"c1plus", "-", 
         RowBox[{"I", " ", "s1plus"}]}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A1bar", "[", "x", "]"}], "]"}], " ", 
         RowBox[{"A1", "[", "x", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"1", "/", "2"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"F1plus", " ", "F1minus"}], "]"}], " ", 
       RowBox[{"(", 
        RowBox[{"c1plus", "+", 
         RowBox[{"I", " ", "s1plus"}]}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"A1", "[", "x", "]"}]}], " ", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"A1bar", "[", "x", "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"1", "/", "2"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"F1plus", " ", "F1minus"}], "]"}]}], " ", 
       RowBox[{"(", 
        RowBox[{"c1plus", "+", 
         RowBox[{"I", " ", "s1plus"}]}], ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"A1bar", "[", "x", "]"}]}], " ", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"A1", "[", "x", "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"1", "/", "2"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"F1plus", " ", "F1minus"}], "]"}]}], " ", 
       RowBox[{"(", 
        RowBox[{"c1plus", "-", 
         RowBox[{"I", " ", "s1plus"}]}], ")"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Interference", " ", "term", " ", "for", " ", 
       RowBox[{"K3pi", " ", "/", " ", "Kpipi0"}]}], "*)"}], 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2", "[", "y", "]"}], "]"}], " ", 
         RowBox[{"A2bar", "[", "y", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{"r2", " ", "p2", " ", "R2", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "spd2"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2bar", "[", "y", "]"}], "]"}], " ", 
         RowBox[{"A2", "[", "y", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{"r2", " ", "p2", " ", "R2", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "spd2"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"A2bar", "[", "y", "]"}]}], " ", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2", "[", "y", "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"-", "r2"}], " ", "p2", " ", "R2", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "spd2"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          RowBox[{"A2", "[", "y", "]"}]}], " ", 
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2bar", "[", "y", "]"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", 
      RowBox[{
       RowBox[{"-", "r2"}], " ", "p2", " ", "R2", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "spd2"}], "]"}]}]}]}], "}"}]}], "//", 
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{"#", ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"R2", ">", "0"}], ",", 
        RowBox[{"R2", "\[Element]", "Reals"}], ",", 
        RowBox[{"c1plus", "\[Element]", "Reals"}], ",", 
        RowBox[{"s1plus", "\[Element]", "Reals"}], ",", 
        RowBox[{"spd2", "\[Element]", "Reals"}], ",", 
        RowBox[{"F1plus", ">", "0"}], ",", 
        RowBox[{"F1minus", ">", "0"}], ",", 
        RowBox[{"p2", ">", "0"}], ",", 
        RowBox[{"r2", ">", "0"}]}], "}"}]}]}], "]"}], "&"}], " "}]], "Input",
 CellChangeTimes->{{3.983082565636413*^9, 3.9830825890698633`*^9}, 
