       "p2"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2", "[", "y", "]"}], "]"}], " ", 
         RowBox[{"A2", "[", "y", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"y", ",", 
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], "->", "p2"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
