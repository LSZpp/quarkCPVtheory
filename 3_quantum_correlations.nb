 CellLabel->"In[86]:=",ExpressionUUID->"9d2d0319-6d15-4b5f-9c9a-ac9efb377712"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{"2", " ", 
    SuperscriptBox["rG", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["RG", "2"]}], ")"}]}], 
   RowBox[{"1", "+", 
    SuperscriptBox["rG", "2"], "-", 
    RowBox[{"2", " ", 
     SuperscriptBox["rG", "2"], " ", 
     SuperscriptBox["RG", "2"], " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", " ", "spdG"}], "]"}]}]}]]}]], "Output",
 CellChangeTimes->{3.983360529241212*^9, 3.983360570496121*^9, 
