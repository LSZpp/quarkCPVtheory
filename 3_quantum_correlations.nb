       "r2"}], "*)"}], 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Conjugate", "[", 
          RowBox[{"A2bar", "[", "y", "]"}], "]"}], " ", 
