Cell[CellGroupData[{

Cell["3) ci and si", "Subsection",
 CellChangeTimes->{{3.983079758900256*^9, 
  3.983079792201721*^9}},ExpressionUUID->"c162d5de-4415-4372-be18-\
ed581f3d0db0"],

Cell["\<\
Consider to KSpipi now, where there are many bins. Let us abstract bini to \
the integral of x from 0.5 to 1, and therefore bin-i to the integral of x \
from -0.5 to -1.  In this case we only need the case with the opposite side \
being Kpipi0/K3pi i.e. with extra kinematic degrees of freedom, because then \
if the opposite side is Kpi, then the coherence factor is simply set to 1.\
\>", "Text",
 CellChangeTimes->{{3.983080077825688*^9, 3.983080198278076*^9}, {
  3.983080910893084*^9, 3.9830809749139137`*^9}, {3.983081105447111*^9, 
  3.983081108943021*^9}, {3.983081188363391*^9, 
  3.983081217946622*^9}},ExpressionUUID->"aff68fb2-1475-484e-b4ed-\
1e170469f117"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Acorr", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"A1", "[", "x", "]"}], " ", 
    RowBox[{"A2bar", "[", "y", "]"}]}], "-", 
   RowBox[{
    RowBox[{"A1bar", "[", "x", "]"}], " ", 
    RowBox[{"A2", "[", "y", "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"YcorrBin", "[", 
   RowBox[{"binLow_", ",", "binHigh_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"FixedPoint", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"#", "/.", " ", 
          RowBox[{
           RowBox[{"Conjugate", "[", 
            RowBox[{"a_", "+", "b_"}], "]"}], ":>", 
           RowBox[{
            RowBox[{"Conjugate", "[", "a", "]"}], "+", 
            RowBox[{"Conjugate", "[", "b", "]"}]}]}]}], "/.", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Conjugate", "[", 
           RowBox[{"a_", " ", "b_"}], "]"}], ":>", 
          RowBox[{
           RowBox[{"Conjugate", "[", "a", "]"}], " ", 
           RowBox[{"Conjugate", "[", "b", "]"}]}]}]}], ")"}], "&"}], ",", 
      RowBox[{
       RowBox[{"Acorr", "[", 
        RowBox[{"x", ",", "y"}], "]"}], " ", 
       RowBox[{"Conjugate", "[", 
        RowBox[{"Acorr", "[", 
         RowBox[{"x", ",", "y"}], "]"}], "]"}]}]}], "]"}], "//", "Expand"}], "//", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Total", "[", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{"term", ",", 
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"xpart", ",", "ypart", ",", "pref"}], "}"}], ",", 
            RowBox[{
             RowBox[{"xpart", "=", 
              RowBox[{"Times", "@@", 
               RowBox[{"Cases", "[", 
                RowBox[{
                 RowBox[{"List", "@@", "term"}], ",", 
                 RowBox[{"f_", "/;", 
                  RowBox[{"!", 
                   RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "x"}], "]"}]}]}]}], "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"ypart", "=", 
              RowBox[{"Times", "@@", 
               RowBox[{"Cases", "[", 
                RowBox[{
                 RowBox[{"List", "@@", "term"}], ",", 
                 RowBox[{"f_", "/;", 
                  RowBox[{"!", 
                   RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "y"}], "]"}]}]}]}], "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"pref", "=", 
              RowBox[{"Times", "@@", 
               RowBox[{"Cases", "[", 
                RowBox[{
                 RowBox[{"List", "@@", "term"}], ",", 
                 RowBox[{"f_", "/;", 
                  RowBox[{
                   RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "x"}], "]"}], "&&", 
                   RowBox[{"FreeQ", "[", 
                    RowBox[{"f", ",", "y"}], "]"}]}]}]}], "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"pref", " ", 
              RowBox[{"Integrate", "[", 
               RowBox[{"xpart", ",", 
                RowBox[{"{", 
                 RowBox[{"x", ",", "binLow", ",", "binHigh"}], "}"}]}], "]"}],
               "*", 
              RowBox[{"Integrate", "[", 
               RowBox[{"ypart", ",", 
                RowBox[{"{", 
                 RowBox[{"y", ",", 
                  RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}]}]}], 
           "]"}]}], "]"}], ",", 
        RowBox[{"List", "@@", "#"}]}], "]"}], "]"}], ")"}], "&"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Yplus", "=", 
  RowBox[{"YcorrBin", "[", 
   RowBox[{
    RowBox[{"1", "/", "2"}], ",", "1"}], "]"}]}], "\n", 
 RowBox[{"Yminus", "=", 
  RowBox[{"YcorrBin", "[", 
   RowBox[{
    RowBox[{"-", "1"}], ",", 
    RowBox[{
     RowBox[{"-", "1"}], "/", "2"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9830812764446993`*^9, 3.9830813225239677`*^9}, 
   3.983082822294661*^9, {3.983082973984107*^9, 3.983083008594431*^9}},
 CellLabel->"In[71]:=",ExpressionUUID->"030a5747-a49f-4d67-bd70-15cc9e0ed40d"],

