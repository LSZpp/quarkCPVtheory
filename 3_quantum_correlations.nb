   3.983022108542561*^9, 3.983022132696293*^9}, 3.983083033461442*^9, 
   3.983429117988358*^9},
 CellLabel->"Out[53]=",ExpressionUUID->"b47f5eeb-dd0d-4b3d-8307-fdb0b294cd89"]
}, Open  ]],

Cell["\<\
It is better to express everything as probabilities. the easiest way to do \
this is, as in the previous notebook, to define everything in terms of the \
relative strong phases:\
\>", "Text",
 CellChangeTimes->{{3.982901803092239*^9, 3.982901861695717*^9}, {
  3.982902131171093*^9, 3.982902188714437*^9}, {3.9829022817905293`*^9, 
  3.982902282545781*^9}},ExpressionUUID->"e44ad00e-d1ca-401f-9eb3-\
567ecc87cfe9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"A1bar", " ", "=", " ", 
  RowBox[{"r1", " ", "A1", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", " ", "I"}], " ", "spd1"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"A2bar", " ", "=", " ", 
  RowBox[{"r2", " ", "A2", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", " ", "I"}], " ", "spd2"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"STPHassumps", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"r1", "\[Element]", "Reals"}], ",", 
     RowBox[{"r2", "\[Element]", "Reals"}], ",", 
     RowBox[{"spd1", "\[Element]", "Reals"}], ",", 
     RowBox[{"spd2", "\[Element]", "Reals"}]}], "}"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.98290219419319*^9, 3.982902300023518*^9}, {
   3.982932451560454*^9, 3.982932451683755*^9}, 3.982932591324555*^9, {
   3.9829409322254457`*^9, 3.982940933928123*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"96abd08c-7542-4147-a8d2-b9a8f9b18a42"],

Cell[BoxData[
 RowBox[{"A1", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "spd1"}]], " ", "r1"}]], "Output",
 CellChangeTimes->{
  3.982902407126607*^9, 3.982932278550269*^9, {3.982932442815234*^9, 
   3.982932453767989*^9}, 3.9829325915865593`*^9, 3.982940511421812*^9, {
   3.982940927451902*^9, 3.982940934568594*^9}, 3.982941107864169*^9, {
   3.982942281266561*^9, 3.9829423262830153`*^9}, {3.982942397049399*^9, 
   3.982942413785788*^9}, 3.9829425628763103`*^9, 3.982989891313019*^9, 
   3.983006958230648*^9, {3.983016873236203*^9, 3.983016900805291*^9}, 
   3.983016974754623*^9, 3.983022046342717*^9, {3.983022108544792*^9, 
   3.9830221326987*^9}, 3.983083033464168*^9, 3.983429117997592*^9},
 CellLabel->"Out[54]=",ExpressionUUID->"0220aa61-3110-4566-8a2b-0ede986ad1c3"],

Cell[BoxData[
 RowBox[{"A2", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "spd2"}]], " ", "r2"}]], "Output",
 CellChangeTimes->{
  3.982902407126607*^9, 3.982932278550269*^9, {3.982932442815234*^9, 
   3.982932453767989*^9}, 3.9829325915865593`*^9, 3.982940511421812*^9, {
   3.982940927451902*^9, 3.982940934568594*^9}, 3.982941107864169*^9, {
   3.982942281266561*^9, 3.9829423262830153`*^9}, {3.982942397049399*^9, 
