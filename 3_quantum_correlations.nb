}, Open  ]],

Cell["\<\
Ultimately, we would like to express the correlated yield in terms of \
probabilities instead of amplitudes, so let\[CloseCurlyQuote]s do that\
\>", "Text",
 CellChangeTimes->{{3.982902326810133*^9, 3.982902334663353*^9}, {
  3.98290238537186*^9, 3.9829023929484673`*^9}, {3.98290243347283*^9, 
  3.9829024485885887`*^9}, {3.9829347532049103`*^9, 
  3.98293477723456*^9}},ExpressionUUID->"8d287822-93ef-43d6-81e9-\
f44a48c4be50"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"YcorrProb", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"FullSimplify", "[", "\[IndentingNewLine]", 
     RowBox[{"Ycorr", ",", "\[IndentingNewLine]", 
      RowBox[{"Assumptions", "->", "STPHassumps"}]}], "\[IndentingNewLine]", 
     "]"}], "/.", " ", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"A1", " ", 
        RowBox[{"Conjugate", "[", "A1", "]"}]}], "->", "p1"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A2", " ", 
        RowBox[{"Conjugate", "[", "A2", "]"}]}], "->", "p2"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A1", " ", 
        RowBox[{"Conjugate", "[", "A1", "]"}], " ", 
        RowBox[{"r1", "^", "2"}]}], "->", "p1bar"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A2", " ", 
        RowBox[{"Conjugate", "[", "A2", "]"}], " ", 
        RowBox[{"r2", "^", "2"}]}], "->", "p2bar"}]}], "\[IndentingNewLine]", 
     "}"}]}], "/.", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Conjugate", "[", "A2", "]"}], "->", 
     RowBox[{"p2", "/", "A2"}]}], "}"}]}]}]], "Input",
 CellChangeTimes->{{3.982934532604327*^9, 3.9829345450475397`*^9}, {
   3.982934580681328*^9, 3.9829345869784203`*^9}, {3.982934789837716*^9, 
   3.9829348022412663`*^9}, {3.982942054164426*^9, 3.982942100599368*^9}, 
   3.9829422106207*^9, {3.982942489648156*^9, 3.982942525211711*^9}, 
   3.982942639104797*^9},
 CellLabel->"In[57]:=",ExpressionUUID->"f52a04d9-409a-4cc6-a990-20e82a8adf46"],

Cell[BoxData[
 RowBox[{"p1", " ", "p2", " ", 
  RowBox[{"(", 
   RowBox[{
    SuperscriptBox["r1", "2"], "+", 
    SuperscriptBox["r2", "2"], "-", 
    RowBox[{"2", " ", "r1", " ", "r2", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"spd1", "-", "spd2"}], "]"}]}]}], ")"}]}]], "Output",
 CellChangeTimes->{
  3.9829345505912657`*^9, 3.9829348079097853`*^9, 3.982940511501886*^9, 
   3.982941107983964*^9, 3.982942057152672*^9, 3.982942101753253*^9, {
   3.982942281349943*^9, 3.9829423280841103`*^9}, {3.982942397117448*^9, 
   3.982942413908506*^9}, 3.98294249190374*^9, 3.9829425264321413`*^9, 
   3.982942562994995*^9, 3.982942640530315*^9, 3.982989891360888*^9, 
   3.983006958350931*^9, {3.9830168733487473`*^9, 3.9830169009248323`*^9}, 
   3.98301697480164*^9, 3.983022046367498*^9, {3.983022108564712*^9, 
   3.983022132720532*^9}, 3.98308303358663*^9, 3.983429118133628*^9},
