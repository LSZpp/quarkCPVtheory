Cell[CellGroupData[{

Cell["3) The DCS time-integrated yield", "Subsection",
 CellChangeTimes->{{3.9828529999163923`*^9, 
  3.982853030072356*^9}},ExpressionUUID->"50fe3116-0f25-45c8-b420-\
f8bd5d586126"],

Cell["Exactly the same, but swap around ACF and ADCS amplitudes.", "Text",
 CellChangeTimes->{{3.982853053984717*^9, 
  3.982853070767075*^9}},ExpressionUUID->"1813cde3-e079-4000-bf6d-\
81bf0c71d939"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"TotalAmpDCS", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"gPxy", "[", "t", "]"}], "ADCS"}], "+", 
    RowBox[{
     RowBox[{"gMxy", "[", "t", "]"}], "ACF"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ProbDtoDCS", "[", "t_", "]"}], " ", "=", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"TotalAmpDCS", " ", 
     RowBox[{"Conjugate", "[", "TotalAmpDCS", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ProbDtoDCSInt", " ", "=", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"ProbDtoDCS", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}], ",", 
     RowBox[{"Assumptions", "->", "TimeIntAssumps"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ProbDtoDCSTruncy", "=", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{"ProbDtoDCSInt", "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"A", "^", "2"}], "/", "W"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "2"}], "}"}]}], "]"}], "//", "Normal"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"ProbDtoDCSTruncxy", "=", 
   RowBox[{
    RowBox[{"Series", "[", 
