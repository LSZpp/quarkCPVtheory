Cell[CellGroupData[{

Cell["1) Strong phase definitions", "Subsection",
 CellChangeTimes->{{3.982729584095584*^9, 3.9827296019977818`*^9}, {
   3.982815037116514*^9, 3.982815043499942*^9}, 
   3.982854018185688*^9},ExpressionUUID->"33f63465-8026-4577-a31f-\
942af1b8c1f3"],

Cell["\<\
The CF and DCS decay amplitudes differ by the strong phase: 
arg(A_DCS A_CF*) = - i delta
Now define A_DCS relative A_CF as \
\>", "Text",
 CellChangeTimes->{{3.982729701891749*^9, 3.982729738181727*^9}, {
  3.982815047414505*^9, 3.982815047561122*^9}, {3.982847670131136*^9, 
  3.982847752013706*^9}, {3.982847791648394*^9, 3.982847797403899*^9}, {
  3.982849669853641*^9, 
  3.982849740673189*^9}},ExpressionUUID->"20337e08-118f-40b9-ba18-\
2b3c0dbe6c66"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ACF", " ", "=", " ", "A"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ADCS", " ", "=", " ", 
   RowBox[{"A", " ", "rD", " ", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "I"}], " ", "spd"}], "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.982849745055361*^9, 3.982849809588806*^9}, {
  3.982849877487006*^9, 3.9828499090477543`*^9}, {3.982850011318664*^9, 
  3.982850055361534*^9}, {3.982850113151421*^9, 3.982850117478112*^9}, {
  3.982850173468684*^9, 3.982850174453691*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"8c432b08-67a1-4506-a7ce-4a40b97727fd"],

Cell["\<\
where, here spd symbolises \[OpenCurlyDoubleQuote]strong phase difference\
\[CloseCurlyDoubleQuote], which is delta. 
Note that if we were to take any physical observables, global phases should \
become unity therefore does not matter. For simplicity let us place this \
global phase convention into ACF, so define it to be a real number.\
\>", "Text",
 CellChangeTimes->{{3.982849814677001*^9, 3.982849842794689*^9}, {
   3.982850064684184*^9, 3.982850110501315*^9}, {3.9828501461360683`*^9, 
   3.982850181362027*^9}, 
   3.982853438626556*^9},ExpressionUUID->"ae17273d-7e87-45cd-a413-\
6fe4c20b2583"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Aassumps", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"A", "\[Element]", "Reals"}], ",", 
     RowBox[{"rD", "\[Element]", "Reals"}], ",", 
     RowBox[{"spd", "\[Element]", "Reals"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9828501785850887`*^9, 3.9828502038886623`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"301b4f48-d2bf-4e8d-aba6-773eff45fb96"],

Cell["To check our convention is correct,", "Text",
 CellChangeTimes->{
  3.982850184931074*^9},ExpressionUUID->"1f0f01a9-3476-4d84-92f7-\
a1196849d290"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ADCSACFstar", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"ADCS", " ", 
     RowBox[{"Conjugate", "[", "ACF", "]"}]}], ",", " ", 
    RowBox[{"Assumptions", "->", "Aassumps"}]}], "]"}], " "}]], "Input",
 CellChangeTimes->{{3.982849850019024*^9, 3.982849901980673*^9}, {
   3.982850209350663*^9, 3.982850226301428*^9}, {3.982851170406312*^9, 
   3.982851183171568*^9}, 3.982851238673964*^9, {3.982851341692049*^9, 
   3.982851356990222*^9}, {3.9828516327661963`*^9, 3.982851640057929*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"98151583-ebea-43a6-9a65-9740fb55ce78"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["A", "2"], " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", "spd"}]], " ", "rD"}]], "Output",
 CellChangeTimes->{
  3.98285012167122*^9, {3.982850206198819*^9, 3.982850226914302*^9}, 
   3.982850829357615*^9, 3.982851200573251*^9, 3.982851252468498*^9, 
   3.982851389085784*^9, 3.982851462498065*^9, 3.982851516579219*^9, 
   3.982851568720105*^9, 3.982851734130116*^9, {3.9828518589393063`*^9, 
   3.9828518862598667`*^9}, 3.982851953984592*^9, 3.982852008525292*^9, 
   3.9828520828838873`*^9, 3.982852113822886*^9, 3.982852964606018*^9, 
   3.982853019105855*^9, 3.9828530492925863`*^9, 3.98285317444907*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"66dd443b-c4e5-426d-ba19-2aeac23c8d2e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["2) The CF time-integrated yield", "Subsection",
 CellChangeTimes->{{3.982852914695609*^9, 3.982852921789958*^9}, {
  3.9828529854475937`*^9, 
  3.9828529899316998`*^9}},ExpressionUUID->"cfd9abaf-7a4f-415d-97a5-\
a36ac7390555"],

Cell[TextData[{
 "Under this convention, the probability of the process of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["D", "TI"], "\[Rule]", 
         SubscriptBox[
          StyleBox["f", "TI"], "CF"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "D\\rightarrow f_{\\text{CF}}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9da647f7-ed7b-4d0c-9971-41c869104ee1"],
 " where f is a CF particular final state becomes"
}], "Text",
 CellChangeTimes->{{3.982850250999007*^9, 3.9828502779012613`*^9}, {
  3.982850945299459*^9, 3.9828509810075083`*^9}, {3.982852927356449*^9, 
  3.9828529290358973`*^9}},ExpressionUUID->"68d6cad9-944d-4cc9-b62c-\
bf965a67e69b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"TotalAmpCF", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"gPxy", "[", "t", "]"}], "ACF"}], "+", 
    RowBox[{
     RowBox[{"gMxy", "[", "t", "]"}], "ADCS"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ProbDtoCF", "[", "t_", "]"}], " ", "=", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"TotalAmpCF", " ", 
     RowBox[{"Conjugate", "[", "TotalAmpCF", "]"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.982850295324214*^9, 3.9828503303844748`*^9}, {
   3.9828503631178637`*^9, 3.9828504429804077`*^9}, 3.982850474238381*^9, {
   3.98285053411213*^9, 3.9828505383728113`*^9}, {3.9828516493648043`*^9, 
   3.9828517074870253`*^9}, {3.9828517926253157`*^9, 3.982851836526813*^9}, {
   3.9828520671611767`*^9, 3.982852071124339*^9}, 3.982852102254427*^9, {
   3.98285294480998*^9, 3.982852945747507*^9}, {3.9828530335002337`*^9, 
   3.982853038716613*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"19fd0759-0621-486f-b859-9a5e78fb9a42"],

Cell["\<\
Now we calculate the time integrated yields, with the physically enforced \
assumptions \
\>", "Text",
 CellChangeTimes->{{3.9828504837877283`*^9, 3.982850494707201*^9}, 
   3.9828506180358753`*^9, {3.982850668573461*^9, 3.9828507416452007`*^9}, {
   3.982850835897911*^9, 3.982850837292369*^9}, {3.98285091005436*^9, 
   3.9828509110062847`*^9}},ExpressionUUID->"9a6eefdf-f939-4408-bbd5-\
c597af3ac3c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"TimeIntAssumps", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"A", "\[Element]", "Reals"}], ",", 
     RowBox[{"rD", "\[Element]", "Reals"}], ",", 
     RowBox[{"spd", "\[Element]", "Reals"}], ",", 
     RowBox[{"M", "\[Element]", "Reals"}], ",", 
     RowBox[{"W", "\[Element]", "Reals"}], ",", 
     RowBox[{"x", "\[Element]", "Reals"}], ",", " ", 
     RowBox[{"y", "\[Element]", "Reals"}], ",", 
     RowBox[{"t", "\[Element]", "Reals"}], ",", 
     RowBox[{"t", ">=", "0"}], ",", 
     RowBox[{"x", ">", "0"}], ",", 
     RowBox[{"y", ">", "0"}], ",", 
     RowBox[{"y", "<", "1"}], ",", 
     RowBox[{"M", ">", "0"}], ",", 
     RowBox[{"W", ">", "0"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.982850844637362*^9, 3.982850887910633*^9}, {
   3.982850924667295*^9, 3.98285094027783*^9}, 3.982851031969368*^9, {
   3.98285110070962*^9, 3.9828511045254297`*^9}, {3.982851994646976*^9, 
   3.982851997564006*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"1cc63792-9050-4754-815e-880d32a225c4"],

Cell["Which gives the time integrated yields as ", "Text",
 CellChangeTimes->{
  3.982850915123598*^9},ExpressionUUID->"47c88b9f-95f3-451f-8c05-\
6c1fa3d33924"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ProbDtoCFInt", " ", "=", " ", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"ProbDtoCF", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "->", "TimeIntAssumps"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982850621292777*^9, 3.982850632601953*^9}, {
  3.982850892525532*^9, 3.982850927394825*^9}, {3.982851069833186*^9, 
  3.982851079660186*^9}, {3.982851383445106*^9, 3.982851397033296*^9}, {
  3.982851434868009*^9, 3.98285144107869*^9}, {3.982851475810618*^9, 
  3.982851499865183*^9}, {3.982851535404333*^9, 3.982851553527952*^9}, {
  3.9828516207050943`*^9, 3.98285162248316*^9}, {3.982852949283231*^9, 
  3.982852951115856*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"476b888b-7619-44f2-b217-750073d79f91"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["A", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "2"}], "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SuperscriptBox["rD", "2"]}], ")"}], " ", 
      SuperscriptBox["x", "2"]}], "+", 
     SuperscriptBox["y", "2"], "-", 
     RowBox[{
      SuperscriptBox["rD", "2"], " ", 
      SuperscriptBox["y", "2"]}], "+", 
     RowBox[{"2", " ", "rD", " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SuperscriptBox["x", "2"]}], ")"}], " ", "y", " ", 
      RowBox[{"Cos", "[", "spd", "]"}]}], "-", 
     RowBox[{"2", " ", "rD", " ", "x", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        SuperscriptBox["y", "2"]}], ")"}], " ", 
      RowBox[{"Sin", "[", "spd", "]"}]}]}], ")"}]}], 
  RowBox[{"2", " ", "W", " ", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     SuperscriptBox["x", "2"]}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     SuperscriptBox["y", "2"]}], ")"}]}]]], "Output",
 CellChangeTimes->{3.982852086413085*^9, 3.982852117261126*^9, 
  3.9828529655825577`*^9, 3.982853020265921*^9, 3.9828530504638567`*^9, 
  3.982853178509412*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"7fda5bee-3c16-499b-80c7-862fef89955c"]
}, Open  ]],

Cell[TextData[{
 "Truncate this neglecting terms of order ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["O", "TI"], "(", 
         RowBox[{
           SubscriptBox[
            StyleBox["r", "TI"], 
            StyleBox["D", "TI"]], 
           SuperscriptBox[
            StyleBox["x", "TI"], "2"], 
           SuperscriptBox[
            StyleBox["y", "TI"], "2"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "O(r_D x^2y^2)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "eafa38a9-866a-4d3e-be91-88a60cc04188"],
 " or higher, and factoring out overall normalisation gives"
}], "Text",
 CellChangeTimes->{{3.982852249655731*^9, 3.982852282011776*^9}, {
  3.982852552384486*^9, 
  3.982852559758078*^9}},ExpressionUUID->"c18141b5-fa74-4c4f-8d4a-\
2fdb5a551705"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ProbDtoCFTruncy", "=", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{"ProbDtoCFInt", "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"A", "^", "2"}], "/", "W"}], ")"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "2"}], "}"}]}], "]"}], "//", "Normal"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"ProbDtoCFTruncxy", "=", 
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{"ProbDtoCFTruncy", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "2"}], "}"}]}], "]"}], "//", "Normal"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ProbDtoCFTrunc", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{"ProbDtoCFTruncxy", ",", 
      RowBox[{"{", 
       RowBox[{"rD", ",", "0", ",", "2"}], "}"}]}], "]"}], "//", "Normal"}], "//",
    "Expand", " "}]}]}], "Input",
 CellChangeTimes->{{3.9828522937908907`*^9, 3.982852339106139*^9}, {
   3.982852388817938*^9, 3.98285238916261*^9}, {3.982852422117895*^9, 
   3.9828525144450493`*^9}, {3.982852546430444*^9, 3.982852548323214*^9}, {
   3.9828526549183073`*^9, 3.9828526921583843`*^9}, {3.9828527444944487`*^9, 
   3.9828527987625437`*^9}, {3.982852838665512*^9, 3.982852869507621*^9}, {
   3.982852954265609*^9, 3.9828529582687407`*^9}, {3.982853128349208*^9, 
   3.982853134344654*^9}, 3.982853315856413*^9},
 CellLabel->"In[40]:=",ExpressionUUID->"0e923625-73e8-493e-bd9a-b98761a516e9"],

Cell[BoxData[
 RowBox[{"1", "-", 
  FractionBox[
   SuperscriptBox["x", "2"], "2"], "+", 
  FractionBox[
   RowBox[{
    SuperscriptBox["rD", "2"], " ", 
    SuperscriptBox["x", "2"]}], "2"], "+", 
